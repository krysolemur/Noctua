{
    "python-envs.pythonProjects": [
        {
            "path": "src",
            "envManager": "ms-python.python:venv",
            "packageManager": "ms-python.python:pip"
        }
    ],
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/.pytest_cache": true,
        "**/venv": true,
        "**/Logs": true,
        "**/resources": true,
        "**/Config": true,
        "**/README.md": true,
        "**/LICENSE": true,
        "**/.gitignore": true
    }
}